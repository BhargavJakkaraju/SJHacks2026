# Copy this file to backend/.env and fill in your values.
# backend/.env is gitignored.

# Required for real 3D generation. Without it, the pipeline falls back to the bundled mock GLB.
# Get a key at https://www.meshy.ai/ → Settings → API Keys.
MESHY_API_KEY=

# Optional: pin the Meshy model. Defaults to "meshy-4".
# MESHY_AI_MODEL=meshy-4

# Optional: provider switch. Only "meshy" is wired up today.
# SKETCH_TO_3D_PROVIDER=meshy

# Optional: polling tunables for long-running Meshy jobs.
# SKETCH_TO_3D_POLL_INTERVAL=3
# SKETCH_TO_3D_POLL_TIMEOUT=300
